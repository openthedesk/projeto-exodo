<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
// ============================================
// PROJECT EXÔDO — MAIN JAVASCRIPT
// ============================================

// --- LOADING SCREEN ---
window.addEventListener('load', () => {
  setTimeout(() => {
    document.getElementById('loader').classList.add('hidden');
    initCounters();
    initTerminal();
  }, 2800);
